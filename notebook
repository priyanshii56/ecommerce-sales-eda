   "source": [
    "# 🛒 E-Commerce Sales Analysis — EDA\n",
    "**Author:** Priyanshi Chauhan  \n",
    "**Dataset:** UCI E-Commerce Data (via Kaggle)  \n",
    "**Tools:** Python, Pandas, Matplotlib, Seaborn"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Import Libraries"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Plot styling\n",
    "plt.rcParams['figure.figsize'] = (12, 5)\n",
    "plt.rcParams['axes.spines.top'] = False\n",
    "plt.rcParams['axes.spines.right'] = False\n",
    "sns.set_palette('Blues_d')\n",
    "\n",
    "import os\n",
    "os.makedirs('images', exist_ok=True)\n",
    "\n",
    "print('Libraries loaded successfully!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Load & Explore Data"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('data.csv', encoding='ISO-8859-1')\n",
    "\n",
    "print('Shape:', df.shape)\n",
    "print('\\nColumns:', df.columns.tolist())\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('--- Dataset Info ---')\n",
    "df.info()\n",
    "print('\\n--- Missing Values ---')\n",
    "print(df.isnull().sum())\n",
    "print('\\n--- Basic Stats ---')\n",
    "df.describe()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Data Cleaning"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Drop rows with missing CustomerID\n",
    "df.dropna(subset=['CustomerID'], inplace=True)\n",
    "\n",
    "# Remove cancelled orders (negative quantities) and invalid prices\n",
    "df = df[df['Quantity'] > 0]\n",
    "df = df[df['UnitPrice'] > 0]\n",
    "\n",
    "# Remove rows with missing descriptions\n",
    "df.dropna(subset=['Description'], inplace=True)\n",
    "\n",
    "# Create Revenue column\n",
    "df['Revenue'] = df['Quantity'] * df['UnitPrice']\n",
    "\n",
    "# Parse dates and extract time features\n",
    "df['InvoiceDate'] = pd.to_datetime(df['InvoiceDate'])\n",
    "df['Month'] = df['InvoiceDate'].dt.to_period('M')\n",
    "df['DayOfWeek'] = df['InvoiceDate'].dt.day_name()\n",
    "df['Hour'] = df['InvoiceDate'].dt.hour\n",
    "\n",
    "print(f'Clean dataset shape: {df.shape}')\n",
    "print(f'Total Revenue: £{df[\"Revenue\"].sum():,.2f}')\n",
    "print(f'Unique Customers: {df[\"CustomerID\"].nunique()}')\n",
    "print(f'Unique Products: {df[\"Description\"].nunique()}')\n",
    "print(f'Countries: {df[\"Country\"].nunique()}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Analysis & Visualizations"]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 4.1 Monthly Revenue Trend"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "monthly_revenue = df.groupby('Month')['Revenue'].sum()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\n",
    "monthly_revenue.plot(kind='line', marker='o', linewidth=2.5, color='steelblue', ax=ax)\n",
    "ax.fill_between(range(len(monthly_revenue)), monthly_revenue.values, alpha=0.1, color='steelblue')\n",
    "ax.set_title('Monthly Revenue Trend (2010–2011)', fontsize=15, fontweight='bold', pad=15)\n",
    "ax.set_xlabel('Month', fontsize=11)\n",
    "ax.set_ylabel('Revenue (£)', fontsize=11)\n",
    "ax.set_xticks(range(len(monthly_revenue)))\n",
    "ax.set_xticklabels([str(m) for m in monthly_revenue.index], rotation=45, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.savefig('images/monthly_revenue.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "peak_month = monthly_revenue.idxmax()\n",
    "print(f'Peak Month: {peak_month} — £{monthly_revenue.max():,.2f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 4.2 Top 10 Countries by Revenue"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "top_countries = df.groupby('Country')['Revenue'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\n",
    "colors = ['#1F4E8F' if i == 0 else '#5B9BD5' for i in range(len(top_countries))]\n",
    "top_countries.plot(kind='bar', color=colors, ax=ax, edgecolor='white')\n",
    "ax.set_title('Top 10 Countries by Revenue', fontsize=15, fontweight='bold', pad=15)\n",
    "ax.set_xlabel('Country', fontsize=11)\n",
    "ax.set_ylabel('Revenue (£)', fontsize=11)\n",
    "ax.set_xticklabels(top_countries.index, rotation=30, ha='right')\n",
    "for i, v in enumerate(top_countries):\n",
    "    ax.text(i, v + 1000, f'£{v/1000:.0f}K', ha='center', fontsize=9)\n",
    "plt.tight_layout()\n",
    "plt.savefig('images/top_countries.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(top_countries)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 4.3 Top 10 Products by Sales Volume"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "top_products = df.groupby('Description')['Quantity'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "top_products.plot(kind='barh', color='coral', ax=ax, edgecolor='white')\n",
    "ax.set_title('Top 10 Products by Sales Volume', fontsize=15, fontweight='bold', pad=15)\n",
    "ax.set_xlabel('Total Quantity Sold', fontsize=11)\n",
    "ax.set_ylabel('')\n",
    "ax.invert_yaxis()\n",
    "plt.tight_layout()\n",
    "plt.savefig('images/top_products.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(top_products)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 4.4 Revenue by Day of Week"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "day_order = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Sunday']\n",
    "day_revenue = df.groupby('DayOfWeek')['Revenue'].sum().reindex(day_order)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "colors = ['#2ecc71' if v == day_revenue.max() else '#95d5b2' for v in day_revenue]\n",
    "day_revenue.plot(kind='bar', color=colors, ax=ax, edgecolor='white')\n",
    "ax.set_title('Revenue by Day of Week', fontsize=15, fontweight='bold', pad=15)\n",
    "ax.set_xlabel('Day', fontsize=11)\n",
    "ax.set_ylabel('Revenue (£)', fontsize=11)\n",
    "ax.set_xticklabels(day_order, rotation=30, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.savefig('images/day_of_week.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f'Best day: {day_revenue.idxmax()} — £{day_revenue.max():,.2f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 5. Summary of Findings"]
  },

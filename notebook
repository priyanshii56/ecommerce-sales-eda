    "print(f'Countries Served:    {df[\"Country\"].nunique():>12,}')\n",
    "print('-' * 50)\n",
    "print(f'Peak Month:          {str(monthly_revenue.idxmax()):>12}')\n",
    "print(f'Top Country:         {top_countries.index[0]:>12}')\n",
